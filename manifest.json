{
    "schemaVersion": "1.3",
    "acapPackageConf": {
        "setup": {
            "appName": "spotifyconnect",
            "friendlyName": "Spotify Connect",
            "version": "1.0.0",
            "vendor": "Bas",
            "embeddedSdkVersion": "3.0",
            "runMode": "respawn"
        },
        "configuration": {
            "settingPage": "index.html",
            "paramConfig": [
                {
                    "name": "DeviceName",
                    "default": "Axis Speaker",
                    "type": "string"
                },
                {
                    "name": "Bitrate",
                    "default": "160",
                    "type": "string"
                }
            ]
        }
    },
    "resources": {
        "linux": {
            "user": {
                "groups": [
                    "audio",
                    "pipewire"
                ]
            }
        }
    }
}
